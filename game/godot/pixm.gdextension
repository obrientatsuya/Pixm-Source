[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.2"

[libraries]
windows.debug.x86_64   = "res://../../target/debug/game.dll"
windows.release.x86_64 = "res://../../target/release/game.dll"
linux.debug.x86_64     = "res://../../target/debug/libgame.so"
linux.release.x86_64   = "res://../../target/release/libgame.so"
macos.debug            = "res://../../target/debug/libgame.dylib"
macos.release          = "res://../../target/release/libgame.dylib"
